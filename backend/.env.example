# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:5000"

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URL=
DB_NAME="repolens"

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
TOKEN_ENCRYPTION_KEY=

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL="http://localhost:5000/auth/github/callback"
GITHUB_TOKEN=

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL=

# ─── LLM Config (Groq via OpenAI-compatible API) ─────────────────────────────
GROQ_API_KEY=
OPENAI_BASE_URL="https://api.groq.com/openai/v1"
LLM_MODEL="llama-3.1-8b-instant"

# ─── Embeddings Config (Transformers Xenova all-MiniLM-L6-v2) ──────────
EMBEDDING_PROVIDER="local"


# ─── Vector DB (Qdrant) ───────────────────────────────────────────────────────
# NOTE: Ensure Qdrant is running (e.g. docker run -p 6333:6333 qdrant/qdrant)
QDRANT_URL=
QDRANT_API_KEY=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Repomix Layer (Optimized for llama-3.1-8b-instant) ─────────────
REPOMIX_CACHE_TTL_HOURS=24

# Char limit per chunk before LLM (30k chars ≈ 7500 tokens; actual LLM input capped at 18k chars ≈ 4500 tokens)
REPOMIX_MAX_CHUNK_CHARS=30000

# Hard cap on total chunk count — auto-merges pairs if exceeded (target: ≤150)
REPOMIX_MAX_CHUNKS=150

# Concurrency=1 + delay to stay within Groq 6000 TPM
REPOMIX_CONCURRENCY=1
REPOMIX_CALL_DELAY_MS=300

# Directory where repositories are auto-cloned for Repomix analysis
# Defaults to <backend_root>/repos if not set
REPOS_DIR=./repos